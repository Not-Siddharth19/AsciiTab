{
  "manifest_version": 3,
  "name": "AsciiTab - Catppuccin",
  "version": "1.0.0",
  "description": "A keyboard-driven new tab dashboard with Catppuccin theming and ASCII aesthetics.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "AsciiTab - Catppuccin",
    "default_icon": {
      "16": "favicon.svg",
      "32": "favicon.svg"
    }
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "favicon.svg",
    "48": "favicon.svg",
    "128": "favicon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "asciitab@siddestech.com",
      "strict_min_version": "109.0",
      "strict_max_version": "135.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}